{
  "name": "dsource-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "next start",
    "lint": "eslint",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:importmap",
    "seed:admin": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload run src/scripts/seedAdmin.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/plugin-seo": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "cross-env": "^7.0.3",
    "framer-motion": "^12.36.0",
    "graphql": "^16.12.0",
    "next": "^16.2.6",
    "payload": "^3.85.0",
    "payload-cloudinary": "2.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@rolldown/binding-darwin-arm64": "^1.1.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5.9.2",
    "vitest": "^4.0.15"
  }
}
